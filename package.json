{
  "name": "todo-app-tests",
  "version": "1.0.0",
  "scripts": {
    "test": "jest --coverage"
  },
  "devDependencies": {
    "bcryptjs": "^3.0.3",
    "cypress": "^13.17.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb-memory-server": "^11.1.0",
    "mongoose": "^9.6.2",
    "supertest": "^7.2.2"
  },
  "jest": {
    "projects": [
      {
        "displayName": "frontend",
        "testEnvironment": "jsdom",
        "testMatch": [
          "**/public/**/*.test.js"
        ],
        "setupFiles": [
          "./public/jest.setup.js"
        ]
      },
      {
        "displayName": "backend",
        "testEnvironment": "node",
        "testMatch": [
          "**/server.test.js"
        ]
      },
	  {
        "displayName": "e2e",
        "testEnvironment": "node",
		"testTimeout": 30000,
        "testMatch": [
          "**/server_e2e.test.js"
        ]
      }
    ]
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
